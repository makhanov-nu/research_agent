# --- Discord ---
# Bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=

# --- LLM ---
# Provider: "openrouter" (default), "anthropic", or "openai".
LLM_PROVIDER=openrouter
# Model id in the provider's namespace.
#   openrouter: anthropic/claude-sonnet-4.6, anthropic/claude-sonnet-4.5, ...
#   anthropic:  claude-sonnet-4-6, claude-opus-4-8, ...
LLM_MODEL=anthropic/claude-sonnet-4.6
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# OpenRouter (OpenAI-compatible). Required when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Alternative providers (only if you switch LLM_PROVIDER):
# ANTHROPIC_API_KEY=

# NOTE: OpenRouter has no embeddings endpoint. Semantic (mem0) memory needs a
# real OpenAI key for embeddings; without it, semantic memory stays disabled
# (chat and episodic/procedural memory still work). See OPENAI_API_KEY below.

# --- MCP servers (the agent's tools) ---
# paperclip: full-text papers, clinical trials, regulatory docs (https://paperclip.gxl.ai)
# Get a key at https://paperclip.gxl.ai/keys  (format: gxl_...)
PAPERCLIP_API_KEY=

# Path to an optional JSON file declaring additional MCP servers.
# See mcp_servers.example.json. Defaults to ./mcp_servers.json if present.
MCP_CONFIG_PATH=mcp_servers.json

# --- Memory (optional; install with: pip install -e ".[memory]") ---
# Postgres DSN. When empty, memory is disabled (in-process state only).
# Matches docker-compose.yml defaults below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_agent
# mem0 uses OpenAI for embeddings (Anthropic has no embeddings API).
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# Context management
SUMMARY_KEEP_LAST=6
SUMMARY_TOKEN_THRESHOLD=24000
NUDGE_EVERY_TOKENS=20000
ARCHIVE_IDLE_DAYS=7

# --- Experiment compute node (the separate GPU box; optional) ---
# When host+user are empty, the experiment runner is disabled.
COMPUTE_SSH_HOST=
COMPUTE_SSH_USER=
COMPUTE_SSH_PORT=22
# Private key path; leave empty to use default keys / ssh-agent.
COMPUTE_SSH_KEY=
# Remote dir for per-experiment workspaces and outputs.
COMPUTE_WORKDIR=~/research_agent_runs
# Default container image (override per experiment).
COMPUTE_BASE_IMAGE=pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime
# Default docker --gpus value ("all", "0", or "" to disable GPU access).
COMPUTE_DEFAULT_GPUS=all
# Require a human !approve in Discord before launching a run.
EXPERIMENT_REQUIRE_APPROVAL=true
JOB_POLL_INTERVAL_SECONDS=60
