# --- Discord ---
# Bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=

# --- LLM ---
# Provider: "openrouter" (default), "anthropic", or "openai".
LLM_PROVIDER=openrouter
# Model id in the provider's namespace.
#   openrouter: anthropic/claude-sonnet-4.6, anthropic/claude-sonnet-4.5, ...
#   anthropic:  claude-sonnet-4-6, claude-opus-4-8, ...
LLM_MODEL=anthropic/claude-sonnet-4.6
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# OpenRouter (OpenAI-compatible). Required when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Alternative providers (only if you switch LLM_PROVIDER):
# ANTHROPIC_API_KEY=

# NOTE: when LLM_PROVIDER=openrouter, semantic-memory embeddings are routed
# through OpenRouter's OpenAI-compatible embeddings endpoint using
# OPENROUTER_API_KEY (model openai/text-embedding-3-small, 1536-dim). No
# separate OpenAI key is needed in that case.

# --- Per-role model overrides (OpenRouter/DeepInfra only) ---
# Comma-separated role=model_slug pairs. E.g. "code_reader=qwen/qwen3.7-plus,methodology=deepseek/deepseek-v4-pro".
# ROLE_MODELS=

# --- MCP servers (the agent's tools) ---
# paperclip: full-text papers, clinical trials, regulatory docs (https://paperclip.gxl.ai)
# Get a key at https://paperclip.gxl.ai/keys  (format: gxl_...)
PAPERCLIP_API_KEY=

# Tavily web search via its hosted MCP server (gives the consortium + literature
# subagent web access). Get a key at https://tavily.com  (format: tvly-...).
TAVILY_API_KEY=

# --- Ideation consortium (two-track scored panel) ---
# Panel = latest reasoning models (verify exact slugs at https://openrouter.ai/models).
CONSORTIUM_MODELS=deepseek/deepseek-v4-pro,z-ai/glm-5.1,qwen/qwen3.7-plus,moonshotai/kimi-k2.6
CONSORTIUM_CHAIR_MODEL=anthropic/claude-opus-4.8
# Turns in the shared debate track (turn 1 opens; the rest react).
CONSORTIUM_DEBATE_TURNS=2

# Path to an optional JSON file declaring additional MCP servers.
# See mcp_servers.example.json. Defaults to ./mcp_servers.json if present.
MCP_CONFIG_PATH=mcp_servers.json

# --- Memory (optional; install with: pip install -e ".[memory]") ---
# Postgres DSN. When empty, memory is disabled (in-process state only).
# Matches docker-compose.yml defaults below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_agent
# mem0 uses OpenAI for embeddings (Anthropic has no embeddings API).
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# Context management
SUMMARY_KEEP_LAST=6
SUMMARY_TOKEN_THRESHOLD=24000
NUDGE_EVERY_TOKENS=20000
ARCHIVE_IDLE_DAYS=7

# Self-improving lessons (reflect-and-recall loop). Subagents recall relevant
# lessons before each job and reflect the finished job into new ones. Recall is a
# top-K vector search, so the prompt stays bounded as the store grows.
LESSONS_ENABLED=true
LESSON_RECALL_LIMIT=5
# Cheap model that distills a finished job into lessons (runs once/job, in the
# background). Used only when OPENROUTER_API_KEY is set; otherwise the default
# agent model (LLM_PROVIDER/LLM_MODEL) is used. Any OpenRouter slug; keep it small.
REFLECTION_MODEL=anthropic/claude-haiku-4.5
REFLECTION_MAX_LESSONS=3

# --- Experiment compute node (the separate GPU box; optional) ---
# When host+user are empty, the experiment runner is disabled.
COMPUTE_SSH_HOST=
COMPUTE_SSH_USER=
COMPUTE_SSH_PORT=22
# Private key path; leave empty to use default keys / ssh-agent.
COMPUTE_SSH_KEY=
# Remote dir for per-experiment workspaces and outputs.
COMPUTE_WORKDIR=~/research_agent_runs
# Base image the universal experiment image is built FROM.
COMPUTE_BASE_IMAGE=pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime
# Universal experiment image (built once per box, or a registry ref to pull).
# Runs use this by default; it bakes the common ML stack (see docker/experiment.Dockerfile).
EXPERIMENT_IMAGE=research-agent/experiment:latest
# Default docker --gpus value ("all", "0", or "" to disable GPU access).
COMPUTE_DEFAULT_GPUS=all
# Shared docker network joining job containers to the MLflow server.
COMPUTE_NETWORK=ra-net
# Persistent HuggingFace cache volume (datasets/weights downloaded once).
COMPUTE_HF_CACHE_VOLUME=ra-hf-cache
# HF token for in-job dataset/model downloads (passed to jobs via env-file).
HF_TOKEN=
# Require a human !approve in Discord before launching a run.
EXPERIMENT_REQUIRE_APPROVAL=true
JOB_POLL_INTERVAL_SECONDS=60

# --- Experiment authoring + tracking ---
# OpenRouter slug for the "Codex" model that writes experiment code.
EXPERIMENT_CODER_MODEL=openai/gpt-5.5
# MLflow tracking server (started as a container on the GPU box).
MLFLOW_ENABLED=true
MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:v2.16.2
MLFLOW_PORT=5000
MLFLOW_VOLUME=ra-mlflow-data
MLFLOW_EXPERIMENT_NAME=research_agent

# --- Web frontend (FastAPI + React SPA; install with: pip install -e ".[web]") ---
WEB_HOST=0.0.0.0
WEB_PORT=8800
# Public URL the browser uses (the WorkOS redirect is <base>/auth/callback).
WEB_BASE_URL=http://localhost:8800
# Long random string used to sign the session cookie.
WEB_SESSION_SECRET=
# Only these emails may sign in ("" = any authenticated WorkOS user).
WEB_ALLOWED_EMAILS=
# WorkOS AuthKit (https://workos.com/docs/authkit/overview)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# --- Observability: Arize Phoenix (free, self-hosted, LOCAL) ---
# Install the obs extra (pip install -e ".[obs]") and run Phoenix
# (docker compose up -d phoenix), then enable here.
PHOENIX_ENABLED=false
PHOENIX_PROJECT=research-agent
# OTLP traces endpoint of your local Phoenix (empty = Phoenix default).
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
# The web app reverse-proxies the Phoenix UI here (so the frontend embeds it).
PHOENIX_INTERNAL_URL=http://localhost:6006
PHOENIX_ROOT_PATH=/phoenix
